# Configurações do Servidor
PORT=8006
HOST=127.0.0.1
DEBUG=True
LOG_LEVEL=INFO

# Banco de Dados
NOVA_DB_PATH=nova_portfolio.db
# Caminhos relativos para outros bancos (caso necessário cruzar dados no ecossistema)
NOVA_DB_PATH=../NOVA/nova_finance.db
APEX_DB_PATH=../APEX/apex_ar.db

# LLM (Claude via LangChain)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4000

# Parâmetros Financeiros Globais
# Taxa livre de risco padrão para Sharpe Ratio (ex: 0.0525 para 5.25% Fed Funds)
DEFAULT_RISK_FREE_RATE=0.0525
# Inflação de longo prazo estimada (ex: 0.03 para 3%)
DEFAULT_INFLATION_RATE=0.03
